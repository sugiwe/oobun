doctype html
html
  head
    meta content="text/html; charset=UTF-8" http-equiv="Content-Type"
    style
      |
        body {
          font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
          line-height: 1.6;
          color: #333;
          max-width: 600px;
          margin: 0 auto;
          padding: 20px;
        }
        .header {
          border-bottom: 2px solid #e5e7eb;
          padding-bottom: 20px;
          margin-bottom: 20px;
        }
        .content {
          background-color: #f9fafb;
          border-radius: 8px;
          padding: 20px;
          margin-bottom: 20px;
        }
        .test-message {
          background-color: #dbeafe;
          border-left: 4px solid #3b82f6;
          padding: 12px 16px;
          margin: 16px 0;
        }
        .button {
          display: inline-block;
          background-color: #111827;
          color: white !important;
          text-decoration: none;
          padding: 12px 24px;
          border-radius: 6px;
          margin: 16px 0;
        }
        .footer {
          border-top: 1px solid #e5e7eb;
          padding-top: 20px;
          margin-top: 20px;
          font-size: 12px;
          color: #6b7280;
        }
        a {
          color: #111827;
        }

  body
    .header
      h1 style="margin: 0; font-size: 24px;" coconikki

    .content
      p
        | こんにちは、
        strong = "@#{@user.username}"
        | さん

      p
        | これは coconikki からのテスト通知メールです。

      .test-message
        = @message

      p
        | メール通知が正常に動作しています。実際の通知メールもこのように届きます。

      = link_to "通知設定を確認", settings_notifications_url, class: "button"

    .footer
      p
        | このメールは coconikki からのテスト通知メールです。
      p
        = link_to "通知設定を変更", settings_notifications_url
        |  ｜
        = link_to "coconikki について", about_url
